# MongoDB connection string
# Local Mongo:        mongodb://localhost:27017/arcade-hub
# MongoDB Atlas:      mongodb+srv://<user>:<password>@<cluster>.mongodb.net/arcade-hub
MONGODB_URI=mongodb://localhost:27017/arcade-hub

# Secret used to sign JWTs - replace with a long random string
# Generate one with: openssl rand -base64 32
JWT_SECRET=replace_with_a_long_random_string

# Port the Express API listens on
PORT=5000

# Allowed origin for CORS (your React dev/production URL)
CLIENT_URL=http://localhost:3000
